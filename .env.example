# ═══════════════════════════════════════════════════════════════
#  PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# ═══════════════════════════════════════════════════════════════
#  Copy this file as .env and fill in your actual values

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# JWT Security (Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_jwt_secret_key_here_generate_a_random_string

# Admin Credentials
ADMIN_EMAIL=admin@edutrack.edu
ADMIN_PASSWORD=admin123

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Frontend URL
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Environment
NODE_ENV=production

# Server Port
PORT=5000
